        <mxCell id="e3" value="3. Forward multipart request&#xa;HTTP POST /damage-assessment/external" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="trip" target="external"><mxGeometry relative="1" as="geometry"/></mxCell>

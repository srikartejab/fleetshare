        <mxCell id="e8" value="8. Severe only: set UNDER_INSPECTION&#xa;gRPC UpdateVehicleStatus" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="external" target="vehicle"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e9" value="9. Return severe blocked assessment" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="external" target="trip"><mxGeometry relative="1" as="geometry"/></mxCell>

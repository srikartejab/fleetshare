        <mxCell id="e1" value="1. Submit pre-trip inspection&#xa;HTTP POST /trip-experience/pre-trip-inspection" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="ui" target="kong"><mxGeometry relative="1" as="geometry"/></mxCell>

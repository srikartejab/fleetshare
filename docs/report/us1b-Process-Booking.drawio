                <mxCell id="e4" value="6. GET /bookings/availability&#xa;vehicleId,startTime,endTime&#xa;8. POST /booking&#xa;create PAYMENT_PENDING booking&#xa;13. GET /booking/{bookingId}&#xa;15. PATCH /booking/{bookingId}/status&#xa;status=CONFIRMED" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;exitX=0.25;exitY=1;exitDx=0;exitDy=0;" parent="1" target="booking" edge="1" source="pb">

                <mxCell id="e6" value="9. Return reserve result&#xa;bookingId,status=PAYMENT_PENDING,&#xa;paymentStatus=REQUIRED,pricing,customerSummary" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block" parent="1" target="kong" edge="1" source="pb">

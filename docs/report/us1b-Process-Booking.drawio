                <mxCell id="note" value="3. Internal validation: endTime must be later than startTime&#xa;15. payment_result(...) is handled internally inside Process Booking Service, not by a separate HTTP callback&#xa;paymentMethod is echoed back to the UI but not forwarded to Payment Service" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1" vertex="1" parent="1">
                    <mxGeometry x="1040" y="140" width="520" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="e1" value="1. POST /process-booking/reserve&#xa;userId,vehicleId,pickupLocation,startTime,endTime,displayedPrice,subscriptionPlanId" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block" parent="1" source="ui" target="kong" edge="1">

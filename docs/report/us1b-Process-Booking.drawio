                <mxCell id="e3" value="4. GET /vehicles/{vehicleId}&#xa;5. gRPC CheckAvailability(vehicleId)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block" parent="1" source="pb" target="vehicle" edge="1">
                    <mxGeometry relative="1" as="geometry"/>

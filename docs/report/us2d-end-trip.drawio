        <mxCell id="trip" value="Trip Experience Service&#xa;(Composite Service)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="590" y="220" width="440" height="80" as="geometry"/></mxCell>
        <mxCell id="end" value="End Trip Service&#xa;(Composite Service)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="590" y="350" width="440" height="90" as="geometry"/></mxCell>
        <mxCell id="vehicle" value="Vehicle Service&#xa;(gRPC lock)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="170" y="570" width="220" height="70" as="geometry"/></mxCell>

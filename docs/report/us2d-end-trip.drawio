        <mxCell id="pricing" value="Pricing Service" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="810" y="570" width="220" height="70" as="geometry"/></mxCell>
        <mxCell id="booking" value="Booking Service" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="1130" y="570" width="220" height="70" as="geometry"/></mxCell>
        <mxCell id="rabbit" value="RabbitMQ&#xa;(conditional payment / notification events)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1320" y="360" width="300" height="90" as="geometry"/></mxCell>
        <mxCell id="note" value="Trip Service also publishes trip.ended during the status patch. That downstream renewal flow is not expanded in this diagram." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;verticalAlign=top;spacing=8;" vertex="1" parent="1"><mxGeometry x="420" y="700" width="420" height="100" as="geometry"/></mxCell>
        <mxCell id="e1" value="1. End-trip request&#xa;HTTP POST /trip-experience/end" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="ui" target="kong"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" value="2. Route request" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="kong" target="trip"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" value="3. Forward end-trip request&#xa;HTTP POST /end-trip/request" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="trip" target="end"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" value="4. Lock vehicle&#xa;gRPC LockVehicle" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="end" target="vehicle"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" value="5. Patch trip to ENDED&#xa;HTTP PATCH /trips/{tripId}/status" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="end" target="tripsvc"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" value="6. Finalize pricing&#xa;HTTP POST /pricing/finalize-trip" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="end" target="pricing"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e7" value="7. Patch final price / reconciliation / status" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="end" target="booking"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e8" value="8. Publish payment / notification events&#xa;AMQP when refund or discount exists" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="end" target="rabbit"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e9" value="9. Final end-trip response" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="end" target="trip"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e10" value="10. Return result to UI" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="trip" target="ui"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="500" y="150"/><mxPoint x="500" y="55"/></Array></mxGeometry></mxCell>

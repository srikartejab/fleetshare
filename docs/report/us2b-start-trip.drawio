                <mxCell id="e1" value="1. Request unlock / start&#xa;HTTP POST /rental-execution/start" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" parent="1" source="ui" target="kong" edge="1">

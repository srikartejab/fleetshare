        <mxCell id="title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=24;fontStyle=1" value="Sub-Scenario 1C - Renewal Reconciliation and Refund Adjustment" vertex="1">
          <mxGeometry height="40" width="830" x="290" y="20" as="geometry" />
        </mxCell>
        <mxCell id="bus" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d9d2e9;strokeColor=#8e7cc3;fontStyle=1" value="RabbitMQ&#xa;Events: subscription.renewed, trip.ended,&#xa;payment.refund_required, payment.refund_completed,&#xa;billing.refund_adjustment_completed" vertex="1">

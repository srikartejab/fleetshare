          <mxGeometry height="70" width="220" x="-160" y="590" as="geometry" />
        </mxCell>
        <mxCell id="customer" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1" value="Customer UI&#xa;(sees refund + notification later via wallet/account fetches)" vertex="1">
          <mxGeometry height="70" width="270" x="-185" y="770" as="geometry" />
        </mxCell>
        <mxCell id="note" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1" value="Trigger paths in current code:&#xa;1. subscription.renewed event&#xa;2. trip.ended catch-up event&#xa;Demo trigger: /ops-console/renewal/simulate -&gt; /renewal-reconciliation/simulate -&gt; publish subscription.renewed" vertex="1">
          <mxGeometry height="120" width="560" x="960" y="70" as="geometry" />
        </mxCell>
        <mxCell id="e1" edge="1" parent="1" source="bus" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;startArrow=block;endArrow=block;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="rr" value="1. Consume: subscription.renewed, trip.ended, payment.refund_completed&#xa;6. Publish: payment.refund_required&#xa;10. Publish: billing.refund_adjustment_completed">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" edge="1" parent="1" source="rr" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;startArrow=block;endArrow=block" target="booking" value="2. GET /bookings/reconciliation-pending?userId&amp;billingCycleId[&amp;bookingId]&#xa;7. PATCH /booking/{bookingId}/reconciliation-state&#xa;First writes REFUND_PENDING with refundPendingOnRenewal=true&#xa;After payment.refund_completed writes COMPLETED, clears refundPendingOnRenewal, status=RECONCILED&#xa;Trip-ended catch-up also does: GET /booking/{bookingId}">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" edge="1" parent="1" source="rr" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;startArrow=block;endArrow=block" target="trip" value="3. GET /trips/{tripId}&lt;div&gt;&lt;br/&gt;&lt;/div&gt;">
          <mxGeometry relative="1" x="0.3478" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e5" edge="1" parent="1" source="rr" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;startArrow=block;endArrow=block" target="pricing" value="2a. POST /pricing/customers/{userId}/renewal&#xa;Idempotent; returns billingCycleId&#xa;4. POST /pricing/re-rate-renewed-booking&#xa;Trip-ended catch-up also does: GET /pricing/customers/{userId}/summary">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" edge="1" parent="1" source="bus" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;exitX=0.25;exitY=1;exitDx=0;exitDy=0;" target="payment" value="8. Consume payment.refund_required&#xa;Persist REFUNDED payment record&#xa;9. Publish payment.refund_completed">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" edge="1" parent="1" source="bus" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block" target="notification" value="11. Consume billing.refund_adjustment_completed&#xa;Persist in-app notification">
          <mxGeometry relative="1" as="geometry" />

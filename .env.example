MYSQL_ROOT_PASSWORD=fleetshare_root
MYSQL_HOST=mysql
MYSQL_PORT=3306
TZ=Asia/Singapore
BILLING_TIMEZONE=Asia/Singapore
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=fleetshare-evidence
# MinIO is the supported evidence store in this release. Azure Blob is not wired in yet.
AZURE_STORAGE_CONNECTION_STRING=
AZURE_VISION_MODE=mock
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# Optional override. Leave blank to use same-origin API routing through the web container.
WEB_API_BASE_URL=
# Unused by the current app runtime; kept only for reference.
KONG_PUBLIC_URL=
# Informational only. The current runtime does not branch on APP_ENV.
APP_ENV=development
DAMAGE_BOOKING_LOOKAHEAD_HOURS=336

